# ================================================================
# BONDHU PLATFORM — ENVIRONMENT CONFIGURATION TEMPLATE
# ================================================================

# ── Application ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Bondhu
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── Database (Primary PostgreSQL + PostGIS) ──────────────────────
POSTGRES_USER=bondhu
POSTGRES_PASSWORD=bondhu_secret
POSTGRES_DB=bondhu
DATABASE_URL=postgresql://bondhu:bondhu_secret@localhost:6432/bondhu?schema=public&pgbouncer=true
DIRECT_DATABASE_URL=postgresql://bondhu:bondhu_secret@localhost:5432/bondhu?schema=public

# ── Cache (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SENTINEL_URL=redis://localhost:26379

# ── Message Queue ────────────────────────────────────────────────
RABBITMQ_URL=amqp://bondhu:bondhu_secret@localhost:5672

# ── Search ───────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Object Storage (MinIO / S3) ──────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=bondhu
MINIO_SECRET_KEY=bondhu_secret
MINIO_BUCKET_NAME=bondhu-media
AWS_S3_REGION=ap-south-1

# ── Security ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-long-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-256-bits-long-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
OTP_SECRET=your-otp-encryption-secret
BCRYPT_ROUNDS=12

# ── WebSocket / Real-time ────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_USER=5

# ── External Services ────────────────────────────────────────────
SMS_PROVIDER_URL=https://api.bdtls.com/sms
SMS_API_KEY=
SMS_SENDER_ID=BONDHU

# bKash Sandbox (MFS integration)
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Nagad Sandbox
NAGAD_BASE_URL=https://sandbox.mynagad.com
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=

# ── Feature Flags ────────────────────────────────────────────────
ENABLE_STORIES=true
ENABLE_REELS=true
ENABLE_LIVE=true
ENABLE_MARKETPLACE=true
ENABLE_FUNDRAISER=true

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=
DATADOG_API_KEY=
