# ============================================================
#  Bondhu - Production Environment Variables
#  Copy this to .env and fill in your actual values
# ============================================================

# ---- App Settings ----
NODE_ENV=production
APP_NAME=Bondhu
APP_URL=https://bondhu.vercel.app
API_URL=https://bondhu-api.up.railway.app

# ---- Database (Supabase or Railway) ----
DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public
DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public

# ---- Redis (Upstash or Railway) ----
REDIS_URL=rediss://default:pass@host:6379

# ---- JWT Secrets (Generate strong random strings) ----
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
OTP_SECRET=your-otp-secret-key

# ---- Cloudflare R2 (S3-compatible storage) ----
# Get these from your Cloudflare R2 dashboard
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=bondhu-media
R2_PUBLIC_URL=https://media.bondhu.app  # Optional: custom domain for public access

# ---- ZeroBounce Email Verification ----
ZEROBOUNCE_API_KEY=your-zerobounce-api-key

# ---- WebSocket ----
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_USER=5

# ---- Feature Flags ----
ENABLE_STORIES=true
ENABLE_REELS=true
ENABLE_LIVE=true
ENABLE_MARKETPLACE=true
ENABLE_FUNDRAISER=true
