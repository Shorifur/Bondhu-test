  @@index([fundraiserId])
  @@map("fundraiser_documents")
}

// ================================================================
// 11. PAYMENTS & ESCROW (Fintech)
// ================================================================

model Payment {
  id              String          @id @default(uuid()) @db.Uuid
  senderId        String          @map("sender_id") @db.Uuid
  receiverId      String?         @map("receiver_id") @db.Uuid
  fundraiserId    String?         @map("fundraiser_id") @db.Uuid
  conversationId  String?         @map("conversation_id") @db.Uuid
  type            PaymentType
  amount          Decimal         @db.Decimal(14, 2)
  currency        String          @default("BDT")
  provider        MfsProvider
  providerTxnId   String?         @map("provider_txn_id")
  status          PaymentStatus   @default(PENDING)
  description     String?
  verifiedVia     VerificationMethod? @map("verified_via")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  sender          User            @relation("PaymentSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User?           @relation("PaymentReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  fundraiser      Fundraiser?     @relation(fields: [fundraiserId], references: [id], onDelete: SetNull)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([status])
  @@index([providerTxnId])
  @@map("payments")
}

model Escrow {
  id              String          @id @default(uuid()) @db.Uuid
  marketplaceItemId String        @map("marketplace_item_id") @db.Uuid
  buyerId         String          @map("buyer_id") @db.Uuid
  sellerId        String          @map("seller_id") @db.Uuid
  amount          Decimal         @db.Decimal(14, 2)
  currency        String          @default("BDT")
  status          EscrowStatus    @default(PENDING)
  buyerConfirmed  Boolean         @default(false) @map("buyer_confirmed")
  sellerConfirmed Boolean         @default(false) @map("seller_confirmed")
  releasedAt      DateTime?       @map("released_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  item            MarketplaceItem @relation(fields: [marketplaceItemId], references: [id], onDelete: Cascade)
  buyer           User            @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller          User            @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("escrows")
}

